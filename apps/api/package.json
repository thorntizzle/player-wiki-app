{
  "name": "campaign-player-wiki-typescript-api",
  "private": true,
  "version": "0.1.0",
  "description": "Fixture-backed TypeScript/Hono API slice for read-only compatibility work.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/server.js",
    "smoke": "node ./tests/smoke.mjs",
    "test:browser-json-compatibility": "node ./tests/browser-json-compatibility.mjs",
    "test:route-parity": "node ./tests/route-parity.mjs",
    "pretest": "npm run build",
    "test": "node ./tests/route-parity.mjs && node ./tests/smoke.mjs"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "better-sqlite3": "12.11.1",
    "fflate": "0.8.2",
    "hono": "4.12.27",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.10.0",
    "typescript": "5.8.2"
  }
}
